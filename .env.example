# =============================================================================
# CAURIS DIGITAL — Variables d'environnement
# -----------------------------------------------------------------------------
# Copiez ce fichier en `.env.local` (qui n'est PAS committé sur Git)
# et remplissez vos vraies valeurs.
# =============================================================================

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://caurisdigital.org

# -----------------------------------------------------------------------------
# Email transactionnel — Resend (https://resend.com)
# -----------------------------------------------------------------------------
# 1. Créer un compte gratuit sur https://resend.com (100 emails/jour gratuits)
# 2. Récupérer une clé API : https://resend.com/api-keys
# 3. (Optionnel) Vérifier le domaine d'envoi sur https://resend.com/domains
#
# 💡 Pour tester rapidement SANS domaine vérifié, Resend fournit l'adresse
#    "onboarding@resend.dev" — les emails de test arrivent dans la boîte
#    de l'email avec lequel le compte Resend a été créé.
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Adresse expéditrice — doit être vérifiée sur Resend (ou onboarding@resend.dev en dev)
CONTACT_EMAIL_FROM=CAURIS DIGITAL <noreply@caurisdigital.org>
# Adresse destinataire des messages reçus via le formulaire
CONTACT_EMAIL_TO=hello@caurisdigital.org

# -----------------------------------------------------------------------------
# Newsletter — Resend Audiences (réutilise RESEND_API_KEY ci-dessus)
# -----------------------------------------------------------------------------
# 1. Aller sur https://resend.com/audiences
# 2. Cliquer sur "Create Audience" → nom : "CAURIS Newsletter"
# 3. Copier l'ID de l'audience (visible dans l'URL : /audiences/XXXX-XXXX-XXXX)
# -----------------------------------------------------------------------------
RESEND_AUDIENCE_ID=

# (Anciens placeholders Mailchimp / Brevo — non utilisés si on reste sur Resend)
# NEWSLETTER_API_KEY=
# NEWSLETTER_LIST_ID=

# -----------------------------------------------------------------------------
# reCAPTCHA v3 — anti-bot sur le formulaire contact (à brancher en phase 2)
# https://www.google.com/recaptcha/admin/create
# -----------------------------------------------------------------------------
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# -----------------------------------------------------------------------------
# CMS headless — Sanity.io (à activer en phase 2)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_READ_TOKEN=
